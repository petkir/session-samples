      "moves": [
        {
          "action": "open",
          "path": "local_00_start/start-llm.sh"
        },
        {
          "action": "highlight",
          "path": "local_00_start/start-llm.sh",
          "position": "3:14",
          "highlightWholeLine": true
        },
        {
          "action": "open",
          "path": "local_00_start/start-llm.sh"
        },
        {
          "action": "openTerminal",
          "terminalId": "ollama"
        },
        {
          "action": "executeTerminalCommand",
          "terminalId": "ollama",
          "command": "cd local_00_start ",
          "insertTypingMode": "character-by-character",
          "insertTypingSpeed": 100
        },
        {
          "action": "executeTerminalCommand",
          "terminalId": "ollama",
          "command": "ollama serve &",
          "autoExecute": true,
          "insertTypingMode": "character-by-character",
          "insertTypingSpeed": 150
        }
      ],
