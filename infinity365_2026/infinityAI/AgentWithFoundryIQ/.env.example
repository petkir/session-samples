# Required
FOUNDRY_PROJECT_ENDPOINT=https://<resource>.services.ai.azure.com/api/projects/<project>
FOUNDRY_MODEL_NAME=gpt-4o-mini

# Required only for `dotnet run -- foundryiq`
FOUNDRYIQ_CONNECTION_NAME=<your-foundryiq-connection-name>

# Optional fallback (same connection, legacy naming)
# WORKIQ_CONNECTION_NAME=<your-workiq-connection-name>
