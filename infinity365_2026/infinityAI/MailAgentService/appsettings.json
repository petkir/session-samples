{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Graph": {
    "TenantId": "<tenant-id>",
    "ClientId": "<app-registration-client-id>",
    "ClientSecret": "<app-registration-client-secret>",
    "MailboxUserId": "mailbox@contoso.com",
    "NotificationUrl": "https://your-service.example.com/api/graph/notifications",
    "LifecycleNotificationUrl": "https://your-service.example.com/api/graph/notifications",
    "ClientState": "<long-random-client-state>",
    "SubscriptionRenewBeforeMinutes": 10,
    "SubscriptionDurationMinutes": 30
  },
  "Agent": {
    "SystemPrompt": "Du bist ein professioneller E-Mail-Assistent. Analysiere eingehende E-Mails und erzeugt eine kurze, freundliche und präzise Antwortvorlage auf Deutsch.",
    "MaxInputCharacters": 12000,
    "DraftSubjectPrefix": "Entwurf: "
  }
}